<view class="page">
  <text class="title-xl settings-title">设置</text>

  <!-- 存储模式 -->
  <view class="settings-section">
    <text class="section-title">数据存储</text>
    <view class="card">
      <view class="storage-option {{storageMode === 'local' ? 'storage-option--active' : ''}}"
        bindtap="switchStorage" data-mode="local">
        <view class="option-radio {{storageMode === 'local' ? 'option-radio--selected' : ''}}">
          <text wx:if="{{storageMode === 'local'}}" class="radio-dot"></text>
        </view>
        <view class="option-info">
          <text class="option-title">本地存储</text>
          <text class="option-desc">数据仅保存在本设备，绝对隐私保护</text>
        </view>
      </view>

      <view class="option-divider"></view>

      <view class="storage-option {{storageMode === 'cloud' ? 'storage-option--active' : ''}}"
        bindtap="switchStorage" data-mode="cloud">
        <view class="option-radio {{storageMode === 'cloud' ? 'option-radio--selected' : ''}}">
          <text wx:if="{{storageMode === 'cloud'}}" class="radio-dot"></text>
        </view>
        <view class="option-info">
          <text class="option-title">云端存储</text>
          <text class="option-desc">数据保存到云端，支持多设备同步</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 提醒设置 -->
  <view class="settings-section">
    <text class="section-title">提醒通知</text>
    <view class="card">
      <view class="settings-row" bindtap="onSubscribe">
        <view class="row-left">
          <text class="row-title">订阅到期提醒</text>
          <text class="row-desc">待办到期时通过微信消息提醒</text>
        </view>
        <text class="row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="settings-section">
    <text class="section-title">数据管理</text>
    <view class="card">
      <view class="settings-row" bindtap="exportData">
        <text class="row-title">导出数据</text>
        <text class="row-arrow">›</text>
      </view>
      <view class="option-divider"></view>
      <view class="settings-row" bindtap="clearData">
        <text class="row-title row-title--danger">清除所有数据</text>
        <text class="row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="settings-section">
    <text class="section-title">关于</text>
    <view class="card">
      <view class="settings-row">
        <text class="row-title">版本</text>
        <text class="row-value">1.0.0</text>
      </view>
      <view class="option-divider"></view>
      <view class="settings-row">
        <text class="row-title">开发者</text>
        <text class="row-value">Frank Su</text>
      </view>
    </view>
  </view>
</view>
