/* === Add Todo — Analog Planner === */
.form-section {
  margin-bottom: var(--space-xl);
}

/* Priority selector — bordered outlines */
.priority-selector {
  display: flex;
  gap: var(--space-sm);
}

.priority-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  background: transparent;
  border: 1rpx solid var(--color-border);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.priority-option:active {
  transform: scale(0.96);
}

.priority-option--active {
  color: var(--text-inverse);
}

.priority-high-active {
  background: var(--color-priority-high);
  border-color: var(--color-priority-high);
}
.priority-medium-active {
  background: var(--color-priority-medium);
  border-color: var(--color-priority-medium);
}
.priority-low-active {
  background: var(--color-priority-low);
  border-color: var(--color-priority-low);
}

.p-bar {
  width: 6rpx;
  height: 20rpx;
  border-radius: 3rpx;
}

.priority-option--active .p-bar {
  background: rgba(255, 255, 255, 0.5) !important;
}

/* Picker field — bottom border style */
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 4rpx;
  background: transparent;
  border-bottom: 1rpx solid var(--color-border);
  border-radius: 0;
  font-size: var(--font-size-base);
  color: var(--text-primary);
}

.picker-field--half {
  flex: 1;
}

.picker-value {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.picker-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-full);
}

.picker-placeholder {
  color: var(--text-disabled);
}

.picker-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

/* Date row */
.date-row {
  display: flex;
  gap: var(--space-sm);
  align-items: center;
}

.clear-date {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: var(--font-size-base);
  flex-shrink: 0;
}

/* Actions */
.form-actions {
  margin-top: var(--space-xxl);
  padding-bottom: var(--space-xl);
}
