.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  box-shadow: 0 2rpx 8rpx rgba(27, 40, 56, 0.06);
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #1B2838;
}

.search-clear {
  font-size: 28rpx;
  color: #8EA3B2;
  padding: 16rpx;
  flex-shrink: 0;
}

/* Filters */
.filter-section {
  margin-bottom: 24rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
}

.filter-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #FFFFFF;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #5A7184;
  border: 2rpx solid #E8E4DD;
}

.pill-arrow {
  font-size: 18rpx;
  color: #B8C4CC;
}

/* Results */
.result-count {
  display: block;
  font-size: 24rpx;
  color: #8EA3B2;
  margin-bottom: 16rpx;
}
