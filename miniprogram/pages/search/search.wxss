/* === Search — Analog Planner === */
.search-bar {
  display: flex;
  align-items: center;
  background: transparent;
  border-bottom: 2rpx solid var(--color-border);
  padding: 0;
  height: 88rpx;
  margin-bottom: var(--space-md);
  transition: border-color var(--transition-fast);
}

.search-bar--focus {
  border-bottom-color: var(--color-sienna);
}

.search-icon {
  font-size: var(--font-size-base);
  color: var(--text-tertiary);
  margin-right: var(--space-sm);
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 88rpx;
  font-size: var(--font-size-base);
  color: var(--text-primary);
}

.search-clear {
  font-size: var(--font-size-base);
  color: var(--text-tertiary);
  padding: var(--space-sm);
  flex-shrink: 0;
}

/* Filters — outlined minimal pills */
.filter-section {
  margin-bottom: var(--space-md);
}

.filter-row {
  display: flex;
  gap: var(--space-sm);
}

.filter-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: transparent;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  border: 1rpx solid var(--color-border);
}

.pill-arrow {
  font-size: 18rpx;
  color: var(--text-tertiary);
}

/* Results */
.result-count {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}
