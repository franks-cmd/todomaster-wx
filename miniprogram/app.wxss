@import './styles/variables.wxss';

/* ============================================
   Global Styles — Analog Planner
   ============================================ */

/* === Reset & Base === */
view, text, navigator, button, input, textarea, picker {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

button {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: inherit;
  font-size: inherit;
}

button::after {
  border: none;
}

/* === Page Container === */
.page {
  min-height: 100vh;
  padding: var(--page-padding);
  padding-bottom: calc(var(--tab-bar-height) + 40rpx);
  background-color: var(--color-ivory);
}

.page--no-tab {
  padding-bottom: var(--page-padding);
}

/* === Card — border-based, no shadow === */
.card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  padding: var(--card-padding);
  border: 1rpx solid var(--color-border);
  background-image: linear-gradient(135deg, rgba(255,255,255,0.6) 0%, transparent 40%);
}

/* === Typography — Serif headers === */
.title-display {
  font-family: var(--font-family-serif);
  font-size: var(--font-size-display);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-tight);
  color: var(--text-primary);
  letter-spacing: var(--letter-spacing-tight);
}

.title-xl {
  font-family: var(--font-family-serif);
  font-size: var(--font-size-xxl);
  font-weight: var(--font-weight-bold);
  line-height: var(--line-height-tight);
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

.title-lg {
  font-family: var(--font-family-serif);
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
}

.title-md {
  font-family: var(--font-family-serif);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
  font-size: var(--font-size-sm);
}

.text-caption {
  color: var(--text-tertiary);
  font-size: var(--font-size-xs);
}

/* === Buttons === */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  font-family: var(--font-family);
  letter-spacing: 1rpx;
  border: 1rpx solid transparent;
  transition: opacity var(--transition-fast);
}

.btn:active {
  opacity: 0.7;
}

.btn-primary {
  background: var(--color-walnut);
  color: var(--text-inverse);
}

.btn-secondary {
  background: transparent;
  color: var(--text-primary);
  border: 1rpx solid var(--color-border);
}

.btn-copper {
  background: var(--color-sienna);
  color: var(--text-inverse);
}

.btn-danger {
  background: transparent;
  color: var(--color-danger);
  border: 1rpx solid var(--color-danger);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
}

.btn-sm {
  height: 64rpx;
  font-size: var(--font-size-sm);
  padding: 0 var(--space-lg);
  border-radius: var(--radius-sm);
}

.btn-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  padding: 0;
}

/* === FAB — Wax seal effect === */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(var(--tab-bar-height) + 40rpx);
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-full);
  background: var(--color-sienna);
  color: var(--text-inverse);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 8rpx 24rpx rgba(196, 87, 42, 0.35),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.25),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  transition: transform var(--transition-base), box-shadow var(--transition-base);
}

.fab:active {
  transform: scale(0.92);
  box-shadow:
    0 4rpx 12rpx rgba(196, 87, 42, 0.25),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.2),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.fab-icon {
  font-size: 52rpx;
  font-weight: 200;
  line-height: 1;
}

/* === Form Elements — Notebook ruled style === */
.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 4rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid var(--color-border);
  border-radius: 0;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  transition: border-color var(--transition-fast);
}

.input-field--focus {
  border-bottom-color: var(--color-sienna);
}

.textarea-field {
  width: 100%;
  min-height: 200rpx;
  padding: var(--space-md) 4rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid var(--color-border);
  border-radius: 0;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: var(--line-height-relaxed);
}

.form-label {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: var(--letter-spacing-label);
  margin-bottom: var(--space-sm);
}

/* === Section === */
.section {
  margin-bottom: var(--space-xl);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

/* === Divider — Ruled line === */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--space-lg) 0;
}

/* === Badge === */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  letter-spacing: 1rpx;
}

/* === Loading === */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(250, 248, 244, 0.7);
  z-index: 999;
}

/* === Animations — Spring ease === */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes springIn {
  from { opacity: 0; transform: translateY(40rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.anim-fade-in {
  animation: fadeIn 500ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.anim-slide-up {
  animation: slideUp 500ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.anim-spring-in {
  animation: springIn 500ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* === Empty State === */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-xl) 80rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: var(--space-lg);
  opacity: 0.2;
}

.empty-text {
  font-family: var(--font-family-serif);
  font-size: var(--font-size-md);
  color: var(--text-tertiary);
  text-align: center;
}
