/* ============================================
   TodoMaster Design System — "Analog Planner"
   Inspired by premium stationery, bullet journals,
   and vintage planners with digital precision.
   ============================================ */

page {
  /* === Primary Palette === */
  --color-walnut: #2A1F14;
  --color-walnut-light: #4A3B2E;
  --color-warm-gray: #8C7E72;
  --color-ivory: #FAF8F4;
  --color-ivory-dark: #F3EFE8;
  --color-white: #FFFFFF;

  /* === Accent Colors === */
  --color-sienna: #C4572A;
  --color-sienna-light: #D4714A;
  --color-sienna-glow: rgba(196, 87, 42, 0.10);
  --color-moss: #4A7C59;
  --color-moss-light: rgba(74, 124, 89, 0.12);

  /* === Priority Colors === */
  --color-priority-high: #C4572A;
  --color-priority-high-bg: rgba(196, 87, 42, 0.08);
  --color-priority-medium: #D4943A;
  --color-priority-medium-bg: rgba(212, 148, 58, 0.08);
  --color-priority-low: #6B8FAD;
  --color-priority-low-bg: rgba(107, 143, 173, 0.08);

  /* === Status Colors === */
  --color-success: #4A7C59;
  --color-danger: #C4572A;
  --color-warning: #D4943A;
  --color-info: #6B8FAD;

  /* === Text Colors === */
  --text-primary: #2A1F14;
  --text-secondary: #8C7E72;
  --text-tertiary: #B5A99B;
  --text-inverse: #FFFFFF;
  --text-disabled: #C9BFB3;

  /* === Typography === */
  --font-family: -apple-system, "SF Pro Text", "Helvetica Neue", "PingFang SC", "Hiragino Sans GB", sans-serif;
  --font-family-serif: Georgia, "Noto Serif SC", "Songti SC", "STSong", serif;
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-md: 30rpx;
  --font-size-lg: 34rpx;
  --font-size-xl: 40rpx;
  --font-size-xxl: 48rpx;
  --font-size-display: 60rpx;
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  --line-height-tight: 1.2;
  --line-height-normal: 1.5;
  --line-height-relaxed: 1.75;
  --letter-spacing-label: 4rpx;
  --letter-spacing-tight: -1rpx;

  /* === Spacing === */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-xxl: 64rpx;

  /* === Border === */
  --color-border: #E8E2D9;
  --border-thin: 1rpx solid #E8E2D9;

  /* === Border Radius === */
  --radius-sm: 6rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-full: 999rpx;

  /* === Shadows (minimal — prefer borders) === */
  --shadow-sm: none;
  --shadow-md: 0 2rpx 8rpx rgba(42, 31, 20, 0.04);
  --shadow-lg: 0 4rpx 16rpx rgba(42, 31, 20, 0.06);
  --shadow-xl: 0 8rpx 24rpx rgba(42, 31, 20, 0.10);

  /* === Transitions === */
  --transition-fast: 150ms ease;
  --transition-base: 250ms ease;
  --transition-slow: 400ms cubic-bezier(0.16, 1, 0.3, 1);
  --transition-spring: 500ms cubic-bezier(0.34, 1.56, 0.64, 1);

  /* === Layout === */
  --page-padding: 32rpx;
  --card-padding: 28rpx;
  --tab-bar-height: 100rpx;

  /* === Apply base styles === */
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  color: var(--text-primary);
  background-color: var(--color-ivory);
  line-height: var(--line-height-normal);
  /* Paper grain texture */
  background-image:
    radial-gradient(circle at 20% 30%, rgba(42, 31, 20, 0.012) 1px, transparent 1px),
    radial-gradient(circle at 80% 70%, rgba(42, 31, 20, 0.008) 1px, transparent 1px);
  background-size: 24px 24px;
}
