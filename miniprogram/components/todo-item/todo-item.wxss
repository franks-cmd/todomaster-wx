/* === Todo Item — Analog Planner === */
.todo-item {
  display: flex;
  align-items: center;
  padding: 24rpx var(--card-padding);
  background: var(--color-white);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-sm);
  border: 1rpx solid var(--color-border);
  transition: transform var(--transition-fast), border-color var(--transition-fast);
  position: relative;
  z-index: 1;
}

.todo-item:active {
  transform: translateY(-2rpx);
  border-color: var(--color-warm-gray);
}

.todo-item--done {
  opacity: 0.55;
}

/* === Checkbox — Bullet Journal Circle === */
.todo-checkbox {
  flex-shrink: 0;
  margin-right: 20rpx;
  padding: 8rpx;
}

.checkbox-inner {
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-spring);
}

.checkbox-inner--checked {
  background: var(--color-moss);
  border-color: var(--color-moss);
  animation: checkBounce 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes checkBounce {
  0% { transform: scale(0.8); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.check-icon {
  color: var(--text-inverse);
  font-size: 24rpx;
  font-weight: 700;
}

/* === Content === */
.todo-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.todo-header {
  margin-bottom: 8rpx;
}

.todo-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-all;
}

.todo-title--done {
  text-decoration: line-through;
  color: var(--text-tertiary);
}

/* === Meta === */
.todo-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.todo-due {
  display: inline-flex;
  align-items: center;
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
}

.todo-due.due-overdue {
  color: var(--color-danger);
}

.todo-due.due-urgent {
  color: var(--color-warning);
}

.due-icon {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.due-text {
  white-space: nowrap;
}

/* === Sort Handle === */
.sort-handle {
  flex-shrink: 0;
  padding: 16rpx;
  margin-left: 8rpx;
}

.handle-icon {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

/* === Swipe Delete === */
.swipe-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: var(--space-sm);
  width: 160rpx;
  background: var(--color-sienna);
  border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
  opacity: 0;
  transition: opacity var(--transition-fast);
}

.swipe-delete--show {
  opacity: 1;
}

.delete-text {
  color: var(--text-inverse);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
}
