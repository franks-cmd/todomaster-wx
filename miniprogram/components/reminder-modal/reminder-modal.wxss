/* === Reminder Modal — Warm Analog Style === */
.reminder-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 31, 20, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.reminder-sheet {
  width: 100%;
  max-height: 70vh;
  background: var(--color-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg) var(--space-lg) var(--space-md);
  border-bottom: 1rpx solid var(--color-border);
}

.sheet-title {
  font-family: var(--font-family-serif);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--text-primary);
}

.sheet-close {
  font-size: 36rpx;
  color: var(--text-tertiary);
  padding: 8rpx;
}

.sheet-body {
  max-height: 50vh;
  padding: var(--space-sm) var(--space-lg) var(--space-lg);
}

.reminder-item {
  padding: var(--space-md);
  background: var(--color-ivory);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-sm);
  border: 1rpx solid var(--color-border);
}

.reminder-item--overdue {
  background: var(--color-priority-high-bg);
  border-left: 6rpx solid var(--color-sienna);
  border-color: var(--color-sienna);
}

.reminder-info {
  margin-bottom: var(--space-sm);
}

.reminder-type-tag {
  display: inline-block;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 8rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.reminder-type-tag.overdue {
  background: var(--color-priority-high-bg);
  color: var(--color-sienna);
}

.reminder-type-tag.upcoming {
  background: var(--color-priority-medium-bg);
  color: var(--color-warning);
}

.reminder-msg {
  display: block;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: var(--line-height-normal);
  margin-top: 8rpx;
}

.reminder-actions {
  display: flex;
  gap: var(--space-sm);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
}

.action-done {
  background: var(--color-moss);
  color: var(--text-inverse);
}

.action-dismiss {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--color-border);
}
