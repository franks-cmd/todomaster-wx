/* === Category Badge — Left Border Tab === */
.category-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  padding-left: 14rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  max-width: 200rpx;
  border-left-width: 4rpx;
  border-left-style: solid;
}

.category-badge--sm {
  padding: 2rpx 10rpx;
  padding-left: 12rpx;
  font-size: 20rpx;
}

.category-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
