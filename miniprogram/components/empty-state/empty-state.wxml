<view class="empty-container anim-fade-in">
  <!-- CSS Geometric Graphic -->
  <view class="empty-graphic">
    <view wx:if="{{graphicType === 'notebook'}}" class="graphic-notebook"></view>
    <view wx:elif="{{graphicType === 'search'}}" class="graphic-search"></view>
    <view wx:else class="graphic-circle"></view>
  </view>

  <text class="empty-title">{{title}}</text>
  <text class="empty-subtitle" wx:if="{{subtitle}}">{{subtitle}}</text>

  <view class="empty-action" wx:if="{{actionText}}" bindtap="onAction">
    <text class="action-text">{{actionText}}</text>
  </view>
</view>
