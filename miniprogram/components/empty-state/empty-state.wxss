.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.25;
}

.empty-text {
  font-size: 30rpx;
  color: #8EA3B2;
  text-align: center;
  line-height: 1.6;
}

.empty-action {
  margin-top: 32rpx;
  padding: 16rpx 40rpx;
  background: #1B2838;
  border-radius: 999rpx;
}

.action-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}
