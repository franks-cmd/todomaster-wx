/* === Priority Tag — Vertical Bar Block === */
.priority-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.priority-bar {
  width: 6rpx;
  height: 20rpx;
  border-radius: 3rpx;
}

.priority-high {
  color: var(--color-priority-high);
}
.priority-high .priority-bar { background: var(--color-priority-high); }

.priority-medium {
  color: var(--color-priority-medium);
}
.priority-medium .priority-bar { background: var(--color-priority-medium); }

.priority-low {
  color: var(--color-priority-low);
}
.priority-low .priority-bar { background: var(--color-priority-low); }
