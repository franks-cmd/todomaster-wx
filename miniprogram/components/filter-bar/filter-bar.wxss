/* === Filter Bar — Editorial Underline Style === */
.filter-bar {
  display: flex;
  white-space: nowrap;
  padding: var(--space-sm) 0;
  margin-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--color-border);
}

.filter-group {
  display: inline-flex;
  gap: 4rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 0;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--text-tertiary);
  background: transparent;
  border: none;
  border-bottom: 3rpx solid transparent;
  margin-right: 4rpx;
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.filter-chip--active {
  color: var(--text-primary);
  border-bottom-color: var(--color-sienna);
}

.filter-divider {
  width: 1rpx;
  height: 32rpx;
  background: var(--color-border);
  margin: 8rpx 12rpx 8rpx 8rpx;
  flex-shrink: 0;
  align-self: center;
}

.cat-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: var(--radius-full);
  margin-right: 6rpx;
  flex-shrink: 0;
}

.priority-bar-inline {
  width: 6rpx;
  height: 18rpx;
  border-radius: 3rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
}
