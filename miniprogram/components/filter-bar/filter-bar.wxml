<scroll-view class="filter-bar" scroll-x enable-flex>
  <!-- 状态筛选 -->
  <view class="filter-group">
    <view class="filter-chip {{activeStatus === 'all' ? 'filter-chip--active' : ''}}"
      bindtap="onStatusChange" data-status="all">
      <text>全部</text>
    </view>
    <view class="filter-chip {{activeStatus === 'active' ? 'filter-chip--active' : ''}}"
      bindtap="onStatusChange" data-status="active">
      <text>进行中</text>
    </view>
    <view class="filter-chip {{activeStatus === 'completed' ? 'filter-chip--active' : ''}}"
      bindtap="onStatusChange" data-status="completed">
      <text>已完成</text>
    </view>
  </view>

  <!-- 分隔线 -->
  <view class="filter-divider"></view>

  <!-- 分类筛选 -->
  <view class="filter-chip {{!activeCategoryId ? 'filter-chip--active' : ''}}"
    bindtap="onCategoryChange" data-id="">
    <text>所有分类</text>
  </view>
  <view class="filter-chip {{activeCategoryId === item.id ? 'filter-chip--active' : ''}}"
    wx:for="{{categories}}" wx:key="id"
    bindtap="onCategoryChange" data-id="{{item.id}}">
    <text class="cat-dot" style="background: {{item.color}};"></text>
    <text>{{item.name}}</text>
  </view>

  <!-- 优先级筛选 -->
  <view class="filter-divider"></view>
  <view class="filter-chip {{!activePriority ? 'filter-chip--active' : ''}}"
    bindtap="onPriorityChange" data-priority="">
    <text>所有优先级</text>
  </view>
  <view class="filter-chip {{activePriority === 'high' ? 'filter-chip--active' : ''}}"
    bindtap="onPriorityChange" data-priority="high">
    <text class="priority-bar-inline" style="background: #C4572A;"></text>
    <text>高</text>
  </view>
  <view class="filter-chip {{activePriority === 'medium' ? 'filter-chip--active' : ''}}"
    bindtap="onPriorityChange" data-priority="medium">
    <text class="priority-bar-inline" style="background: #D4943A;"></text>
    <text>中</text>
  </view>
  <view class="filter-chip {{activePriority === 'low' ? 'filter-chip--active' : ''}}"
    bindtap="onPriorityChange" data-priority="low">
    <text class="priority-bar-inline" style="background: #6B8FAD;"></text>
    <text>低</text>
  </view>
</scroll-view>
