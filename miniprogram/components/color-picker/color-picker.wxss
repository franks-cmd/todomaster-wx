/* === Color Picker — Square Swatches === */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-item {
  width: 68rpx;
  height: 68rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--transition-fast);
  position: relative;
  border: 2rpx solid transparent;
}

.color-item:active {
  transform: scale(0.92);
}

.color-item--selected {
  transform: scale(1.05);
  border-color: var(--text-primary);
  box-shadow: 0 0 0 3rpx var(--color-ivory);
}

.color-check {
  color: var(--text-inverse);
  font-size: 28rpx;
  font-weight: 700;
}
